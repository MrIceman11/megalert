# ── Megalert API ────────────────────────────────────────────────────────────
MEGALERT_HOST=0.0.0.0
MEGALERT_PORT=5000
MEGALERT_DEBUG=false

# ── MikroTik device ──────────────────────────────────────────────────────────
MIKROTIK_HOST=192.168.10.2
MIKROTIK_PORT=8728
MIKROTIK_USER=sms-api
MIKROTIK_PASS=secret
MIKROTIK_SMS_PORT=lte1

# ── Authentication ────────────────────────────────────────────────────────────
# Primary token — use as: Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me

# ── Validation ────────────────────────────────────────────────────────────────
# Comma-separated country calling codes (without +). Leave empty to allow all.
ALLOWED_COUNTRY_CODES=49
# Maximum SMS character length before splitting (max 480 for 3 parts)
MAX_MESSAGE_LENGTH=480

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
